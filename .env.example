# Alpaca credentials — get from https://alpaca.markets/
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paper trading (true = paper, false = live)
# ALWAYS start with true. Only change to false after thorough paper testing.
ALPACA_PAPER=true

# Discord webhook for trade notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# FRED API key — for live 10Y-2Y yield curve data (free at fred.stlouisfed.org)
# Falls back to yfinance TNX/IRX proxy if not set.
FRED_API_KEY=

# Alpha Vantage API key — for real-time sector performance in breadth module
# Free tier: 25 requests/day (breadth module caches 15 min, uses ~3-5/day)
# Active key: set in Railway as environment variable (do not commit to git)
ALPHA_VANTAGE_KEY=MJPYGUFEZQ9C1QMM

# Alpha Vantage MCP server (optional — for LLM-assisted analysis via MCP protocol)
# Start with: uvx marketdata-mcp-server MJPYGUFEZQ9C1QMM
# Or via URL:  https://mcp.alphavantage.co/mcp?apikey=MJPYGUFEZQ9C1QMM
# The bot itself does NOT use MCP — this is for manual analysis sessions.
# ALPHA_VANTAGE_MCP_URL=https://mcp.alphavantage.co/mcp?apikey=MJPYGUFEZQ9C1QMM

# Finnhub API key — optional, for CPI/NFP event calendar
# Free tier: https://finnhub.io/
FINNHUB_API_KEY=

# PostgreSQL — Railway injects this automatically when you add a Postgres plugin
# Leave blank for local SQLite fallback
DATABASE_URL=

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
