# ============================================================
# Options Bot — Environment Variables
# ============================================================

# ── Alpaca Credentials ───────────────────────────────────────
# Get from: https://app.alpaca.markets → API Keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Trading Mode ─────────────────────────────────────────────
# PAPER MODE (default — safe, no real money):
ALPACA_PAPER=true

# LIVE MODE (real money):
# 1. Complete paper trading — bot shows "READY FOR LIVE TRADING" in Discord
#    (requires 30+ closed trades, win rate >= 60%, profit factor >= 1.3)
# 2. Enable options trading in Alpaca dashboard:
#    https://app.alpaca.markets → Account → Options Trading
#    (need Level 2 for spreads / strangles)
# 3. Fund your live Alpaca account
# 4. Set ALPACA_PAPER=false AND set ALPACA_API_KEY/SECRET to your LIVE keys
#    (live and paper keys are different — get them from app.alpaca.markets)
# 5. Deploy to Railway with the updated env vars
# 6. The bot will run an interactive pre-flight checklist on startup
#    and require you to type "I understand this is real money" to proceed
#
# ALPACA_PAPER=false

# ── Notifications ────────────────────────────────────────────
# Discord webhook for trade alerts, daily summaries, go-live readiness reports
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1515310987304112198/_QW_aOfwTTENvcaIkpAibkEOma5igUYDyYdwKW5eDdvfqhk0E30IoXd1-BuLJ2Ewjm34

# ── Market Data ──────────────────────────────────────────────
# FRED API key — for live 10Y-2Y yield curve data (free at fred.stlouisfed.org)
# Falls back to yfinance TNX/IRX proxy if not set.
FRED_API_KEY=

# Alpha Vantage API key — for real-time sector performance in breadth module
# Free tier: 25 requests/day (breadth module caches 15 min, uses ~3-5/day)
ALPHA_VANTAGE_KEY=MJPYGUFEZQ9C1QMM

# Finnhub API key — optional, for CPI/NFP economic event calendar
# Free tier: https://finnhub.io/
FINNHUB_API_KEY=

# ── Database ─────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you add a Postgres plugin.
# Leave blank to use local SQLite fallback (fine for paper trading).
DATABASE_URL=

# ── Logging ──────────────────────────────────────────────────
# DEBUG = verbose (good for local dev), INFO = normal, WARNING = quiet
LOG_LEVEL=INFO

# ── Health Check ─────────────────────────────────────────────
# Port for the Railway health check endpoint (GET /health).
# Default 8080 — only change if you have a port conflict.
# HEALTH_PORT=8080
